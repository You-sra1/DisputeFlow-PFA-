# URL de base de l'API backend Express.
# Par défaut le backend tourne sur http://localhost:5000 (voir backend/.env PORT).
# Si le frontend est servi depuis une IP réseau différente de celle du backend,
# remplace cette valeur par l'IP réellement joignable (ex: http://192.168.x.x:5000).
VITE_API_URL=http://localhost:5000
