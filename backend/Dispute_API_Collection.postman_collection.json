            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.length).to.be.above(0);",
            "d.data.forEach(i => { pm.expect(i).to.have.property('disputeId'); pm.expect(i).to.have.property('status'); });"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/disputes?status=ALL",
