{
  "info": {
    "name": "Dispute Chargeback API (11 CDC endpoints + tests)",
    "description": "Base URL : http://localhost:5000/api\n\nComptes de test (Password123) :\n  CLIENT   : client001@example.com\n  CLIENT   : client002@example.com\n  OPERATOR : operator@example.com\n\nWorkflow testé : TXN006 (aucun litige existant) → create → review → request-info → respond → approve → chargeback → refund → close\n\nFichier : backend/Dispute_API_Collection.postman_collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "clientToken", "value": "" },
    { "key": "operatorToken", "value": "" },
    { "key": "newDisputeId", "value": "" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "01 - POST /login (Client)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.errorCode).to.eql('00000');",
            "pm.expect(d.data).to.have.property('token');",
            "pm.expect(d.data.user.id).to.eql('CLIENT001');",
            "pm.expect(d.data.user.role).to.eql('CLIENT');",
            "pm.collectionVariables.set('clientToken', d.data.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"e1d38c5b-fd9e-42d0-9269-089d91d3d234\",\n    \"requestDate\": \"2026-07-14T09:00:00Z\",\n    \"userID\": \"anonymous\"\n  },\n  \"email\": \"client001@example.com\",\n  \"password\": \"Password123\"\n}" }
          }
        },
        {
          "name": "02 - POST /login (Operator)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.errorCode).to.eql('00000');",
            "pm.expect(d.data.user.role).to.eql('OPERATOR');",
            "pm.collectionVariables.set('operatorToken', d.data.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"requestDate\": \"2026-07-14T09:00:00Z\",\n    \"userID\": \"anonymous\"\n  },\n  \"email\": \"operator@example.com\",\n  \"password\": \"Password123\"\n}" }
          }
        },
        {
          "name": "03 - GET /me (Client profile)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.id).to.eql('CLIENT001');",
            "pm.expect(d.data.email).to.eql('client001@example.com');",
            "pm.expect(d.data.role).to.eql('CLIENT');"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }]
          }
        }
      ]
    },
    {
      "name": "READ-ONLY (Cards & Transactions)",
      "item": [
        {
          "name": "04 - GET /cards",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.length).to.be.above(0);",
            "pm.expect(d.data[0]).to.have.property('cardId');",
            "pm.expect(d.data[0]).to.have.property('cardNumber');",
            "pm.expect(d.data[0]).to.have.property('brand');"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/cards",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }]
          }
        },
        {
          "name": "05 - GET /transactions (all)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.length).to.be.above(0);",
            "pm.expect(d.data[0]).to.have.property('transactionId');",
            "pm.expect(d.data[0]).to.have.property('merchant');",
