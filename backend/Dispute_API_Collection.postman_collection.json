    },
    {
      "name": "WORKFLOW (full lifecycle on new dispute)",
      "description": "Test complet du workflow : SUBMITTED → UNDER_REVIEW → WAITING_FOR_INFORMATION → respond → UNDER_REVIEW → APPROVED → CHARGEBACK → REFUND → CLOSED",
      "item": [
        {
          "name": "13 - PUT /review (SUBMITTED → UNDER_REVIEW)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('UNDER_REVIEW');",
            "pm.expect(d.data.reviewedBy).to.eql('OPERATOR001');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/review",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"0f0a90af-2357-4cb5-b50b-4a5ef7cbec90\",\n    \"requestDate\": \"2026-07-14T10:00:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"comment\": \"Dispute assigned for investigation.\"\n}" }
          }
        },
        {
          "name": "14 - PUT /request-info (UNDER_REVIEW → WAITING)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('WAITING_FOR_INFORMATION');",
            "pm.expect(d.data.requestedInformation).to.be.a('string');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/request-info",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"2c1b1de7-a77e-4f55-a2fa-03d5d4a1ec98\",\n    \"requestDate\": \"2026-07-14T10:20:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"message\": \"Merci de fournir la preuve d'identité et le relevé bancaire.\"\n}" }
          }
        },
        {
          "name": "15 - PUT /disputes/:id/respond (WAITING → UNDER_REVIEW, CLIENT)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('UNDER_REVIEW');",
            "pm.expect(d.data.respondedBy).to.eql('CLIENT001');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/disputes/{{newDisputeId}}/respond",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Voici les documents demandés : relevé bancaire et pièce d'identité.\"\n}" }
          }
        },
        {
          "name": "16 - PUT /approve (UNDER_REVIEW → APPROVED)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('APPROVED');",
            "pm.expect(d.data.approvedBy).to.eql('OPERATOR001');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"d3c85db7-8662-4b16-95db-c879bd54eb83\",\n    \"requestDate\": \"2026-07-14T11:00:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"comment\": \"Evidence verified. Transaction not authorized by cardholder.\"\n}" }
          }
        },
        {
          "name": "17 - PUT /chargeback (APPROVED → CHARGEBACK_INITIATED)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('CHARGEBACK_INITIATED');",
            "pm.expect(d.data).to.have.property('chargebackReference');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/chargeback",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"66bc2cc8-78a2-4f77-b920-0c9712afef1d\",\n    \"requestDate\": \"2026-07-14T11:30:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"chargebackReasonCode\": \"4837\",\n  \"network\": \"Mastercard\",\n  \"comment\": \"Chargeback initiated.\"\n}" }
          }
        },
        {
          "name": "18 - PUT /refund (CHARGEBACK → REFUND_COMPLETED)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('REFUND_COMPLETED');",
            "pm.expect(d.data.refundAmount).to.eql(199.99);",
            "pm.expect(d.data.currency).to.eql('USD');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/refund",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"e10d2559-30aa-4bb6-86d7-b95a7b3fbe18\",\n    \"requestDate\": \"2026-07-14T12:00:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"refundAmount\": 199.99,\n  \"currency\": \"USD\",\n  \"refundMethod\": \"CARD_CREDIT\"\n}" }
          }
        },
        {
          "name": "19 - PUT /close (REFUND_COMPLETED → CLOSED)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('CLOSED');",
            "pm.expect(d.data).to.have.property('closedDate');"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/close",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"d514d03d-2eb8-4e35-b1e5-4bcbdd83536f\",\n    \"requestDate\": \"2026-07-14T12:30:00Z\",\n    \"userID\": \"OPERATOR001\"\n  },\n  \"disputeId\": \"{{newDisputeId}}\",\n  \"closureReason\": \"REFUND_ISSUED\",\n  \"comment\": \"Dispute closed after successful refund.\"\n}" }
          }
        }
      ]
    },
