    {
      "name": "DISPUTES - Create",
      "item": [
        {
          "name": "10 - POST /disputes (new dispute on TXN006)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "var d = pm.response.json();",
            "pm.expect(d.data.status).to.eql('SUBMITTED');",
            "pm.expect(d.data.transactionId).to.eql('TXN006');",
            "pm.collectionVariables.set('newDisputeId', d.data.disputeId);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/disputes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"684d92a6-9e8b-4a42-b29b-72f4cbf3a5ef\",\n    \"requestDate\": \"2026-07-14T09:20:00Z\",\n    \"userID\": \"CLIENT001\"\n  },\n  \"transactionId\": \"TXN006\",\n  \"reason\": \"UNAUTHORIZED_TRANSACTION\",\n  \"description\": \"Je n'ai pas autorisé cette transaction Apple Store.\",\n  \"claimAmount\": 199.99,\n  \"currency\": \"USD\"\n}" }
          }
        },
