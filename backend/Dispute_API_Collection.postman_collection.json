            ],
            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"684d92a6-9e8b-4a42-b29b-72f4cbf3a5ef\",\n    \"requestDate\": \"2026-07-14T09:22:00Z\",\n    \"userID\": \"CLIENT001\"\n  },\n  \"reason\": \"FRAUD\",\n  \"description\": \"Test sans transactionId.\",\n  \"claimAmount\": 100,\n  \"currency\": \"USD\"\n}" }
          }
