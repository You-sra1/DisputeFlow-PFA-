            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }]
          }
        },
        {
          "name": "06 - GET /transactions (filtered by date)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "var d = pm.response.json();",
            "pm.expect(d.data.length).to.be.above(0);",
            "d.data.forEach(t => pm.expect(t.transactionDate >= '2026-06-15').to.be.true);",
            "d.data.forEach(t => pm.expect(t.transactionDate <= '2026-07-10').to.be.true);"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/transactions?startDate=2026-06-15&endDate=2026-07-10",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }]
          }
        }
      ]
    },
    {
      "name": "DISPUTES - Read",
