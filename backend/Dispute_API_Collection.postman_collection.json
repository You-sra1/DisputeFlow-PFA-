            "body": { "mode": "raw", "raw": "{\n  \"requestInfo\": {\n    \"requestUID\": \"684d92a6-9e8b-4a42-b29b-72f4cbf3a5ef\",\n    \"requestDate\": \"2026-07-14T09:21:00Z\",\n    \"userID\": \"CLIENT001\"\n  },\n  \"transactionId\": \"TXN006\",\n  \"reason\": \"FRAUD\",\n  \"description\": \"Deuxième tentative sur la même transaction.\",\n  \"claimAmount\": 199.99,\n  \"currency\": \"USD\"\n}" }
          }
